# ============================================================
# aistock backend .env.example → 复制为 .env 并填入真实值
# ============================================================

# 必填：统一数据根目录（lake/parquet、duckdb、tusharedb-go 缓存等均在此目录下）
# 注意：本仓库不含 a-stock-data/ 目录；UZI-Skill 文档中的 a-stock-data 对应此 AI_DATA_DIR
AI_DATA_DIR=/Users/leven/data/aistock

# 服务端口
PORT=8787

# Tushare 数据源（https://tushare.pro 注册获取）
TUSHARE_TOKEN=

# AI 模型（DeepSeek / OpenAI / 本地 Ollama 等）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat

# 可选：游资看盘 UZI-Skill 集成（相对 backend/ 目录；未设置时会自动探测仓库根 UZI-Skill/）
# 目录结构（legacy 优先）：skills/deep-analysis/scripts/ · run.py 在仓库根 · requirements.txt 在根
# v3.6+ 扁平布局 fallback：deep-analysis/scripts/（服务端若仍用旧 sync 可设 /data/UZI-SKILL）
# UZI-Skill 需要 Python 3.10+；系统默认 python3 若是 3.6/3.7 会报 SyntaxError: future feature annotations
HOTMONEY_UZI_DIR=../UZI-Skill
# 推荐：在 UZI 根目录 python3.11 -m venv .venv && pip install -r requirements.txt 后指向 venv
# HOTMONEY_UZI_PYTHON=/data/UZI-Skill/.venv/bin/python
# HOTMONEY_UZI_DIR=/data/UZI-Skill
# HOTMONEY_REPORT_MODE=llm  # 默认 uzi；设为 llm 可启用快速 LLM 报告（开发用）
#
# --- 生产环境 UZI 调优（小 VPS 必读）---
# depth 默认 lite（代码内 fallback）；deep 会显著增加内存与耗时，2GB 以下机器勿用 deep
HOTMONEY_UZI_DEPTH=lite
# 子进程超时，默认 25m；CommandContext 到期会以 SIGKILL 结束 Python，日志可能显示 signal: killed
HOTMONEY_UZI_TIMEOUT=25m
# 若前面有 Nginx/Caddy 反代，SSE 需关闭缓冲并拉长读超时，例如：
#   proxy_buffering off;
#   proxy_read_timeout 1800s;   # ≥ HOTMONEY_UZI_TIMEOUT
#   proxy_http_version 1.1;
# 服务端已设置 X-Accel-Buffering: no
# 排查 OOM：free -h && dmesg | tail -50 | grep -iE 'oom|killed process'

# 可选：分析报告 SQLite 路径
# AIGOSTOCK_SQLITE_PATH=data/aigostock.db

# 可选：认证
# AUTH_JWT_SECRET=change_me_in_production

# 可选：StockAPI 缓存
# STOCKAPI_CACHE_MODE=auto
